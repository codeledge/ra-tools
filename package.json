{
  "name": "ra-tools",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "turbo run test",
    "dev": "turbo run dev --parallel --cache=local:r,remote:r",
    "build": "turbo run build",
    "kill": "pnpm run kill --filter apps/*"
  },
  "devDependencies": {
    "turbo": "^2.8.16"
  },
  "packageManager": "pnpm@10.32.1"
}
